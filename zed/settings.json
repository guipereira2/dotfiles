// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "edit_predictions": {
        "provider": "none",
    },
    "project_panel": {},
    "outline_panel": {},
    "git_panel": {},
    "code_lens": "on",
    "icon_theme": "JetBrains New UI Icons (Dark)",
    "cli_default_open_behavior": "existing_window",
    "agent": {
        "dock": "right",
        "sidebar_side": "right",
        "favorite_models": [],
        "model_parameters": [],
    },
    "telemetry": {
        "diagnostics": true,
        "metrics": false,
    },
    "vim_mode": true,
    "terminal": {
        "font_size": 14.0,
        "font_family": "JetBrainsMono Nerd Font",
        "button": true,
        "dock": "right",
    },
    "preview_tabs": {
        "enabled": false,
    },
    "status_bar": {
        "active_encoding_button": "disabled",
        "cursor_position_button": false,
    },
    "scrollbar": {
        "axes": {
            "horizontal": false,
            "vertical": false,
        },
    },
    "buffer_line_height": "comfortable",
    "cursor_blink": true,
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "show_edit_predictions": true,
    "soft_wrap": "editor_width",
    "hard_tabs": false,
    "tab_size": 4,
    "agent_servers": {
        "claude-acp": {
            "default_config_options": {
                "model": "haiku",
            },
            "type": "registry",
        },
    },
    "base_keymap": "VSCode",
    "ui_font_size": 16,
    "buffer_font_size": 15,
    "theme": {
        "mode": "system",
        "light": "One Light",
        "dark": "Min Dark (Blurred)",
    },
    "toolbar": {
        "quick_actions": false,
        "code_actions": false,
        "breadcrumbs": true,
    },
    "inline_code_actions": true,
    "collaboration_panel": {
        "button": false,
    },
    "title_bar": {
        "show_sign_in": true,
        "show_menus": false,
        "show_user_picture": true,
    },
    "git": {
        "inline_blame": {
            "enabled": false,
        },
    },
    "debugger": {
        "button": false,
    },
    "restore_on_startup": "launchpad",
    "tabs": {
        "file_icons": true,
    },
    "theme_overrides": {
        "Min Dark (Blurred)": {
            "editor.document_highlight.bracket_background": "#B392F185",
            "text.accent": "#ffffff",
            "background": "#1A1A1Ac0", // "background": "#1A1A1Ac0" se quiser blur no dock da direita
            "status_bar.background": "#1A1A1Ac0",
            "title_bar.background": "#1A1A1Ac0",
            "title_bar.inactive_background": "#1A1A1Ac0",
            "toolbar.background": "#1A1A1A", // "background": "#1A1A1Ac0" se quiser blur no editor principal
            "tab_bar.background": "#1A1A1A", // "background": "#1A1A1Ac0" se quiser blur no editor principal
            "tab.inactive_background": "#1A1A1Ac0",
            "tab.active_background": "#1A1A1Ac0",
            "editor.background": "#1A1A1A", // "background": "#1A1A1Ac0" se quiser blur no editor principal
            "editor.gutter.background": "#1A1A1A", //"background": "#1A1A1Ac0" se quiser blur no editor principal
            "terminal.background": "#1A1A1Ac0",
            "element.selected": "#2A2A2A",
            "ghost_element.selected": "#2A2A2A",
            "panel.focused_border": "#2A2A2A",
            "players": [
                {
                    "cursor": "#ffffff",
                    "background": "#ffffff",
                    "selection": "#ffffff30",
                },
            ],
        },
    },
}
